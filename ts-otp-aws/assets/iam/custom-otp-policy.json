{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "OTPTableReadWrite",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem"
      ],
      "Resource": "REPLACE_WITH_DYNAMODB_TABLE_ARN"
    },
    {
      "Sid": "SESSendTransactionalEmail",
      "Effect": "Allow",
      "Action": [
        "ses:SendEmail",
        "ses:SendRawEmail"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "ses:FromAddress": "REPLACE_WITH_VERIFIED_SES_FROM_ADDRESS"
        }
      }
    },
    {
      "Sid": "SNSPublishSMS",
      "Effect": "Allow",
      "Action": "sns:Publish",
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:log-group:/aws/lambda/*-otp:*"
    }
  ]
}
